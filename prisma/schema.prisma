generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}
datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  schemas   = ["marvics"]
}
enum UserRole {
  USER
  SUPPORT
  COMPLIANCE
  SUPER_ADMIN
  @@schema("marvics")
}
enum AccountStatus {
  ACTIVE
  FROZEN
  RESTRICTED
  DELETED
  @@schema("marvics")
}
enum KycStatus {
  NOT_STARTED
  PENDING
  VERIFIED
  REJECTED
  @@schema("marvics")
}
enum LedgerEntryType {
  DEPOSIT
  WITHDRAWAL
  TRADE_BUY
  TRADE_SELL
  CONVERSION_OUT
  CONVERSION_IN
  TRANSFER_OUT
  TRANSFER_IN
  REFERRAL_REWARD
  FEE
  ADMIN_ADJUSTMENT
  @@schema("marvics")
}
enum DepositStatus {
  PENDING
  CONFIRMED
  CREDITED
  FAILED
  @@schema("marvics")
}
enum OrderSide {
  BUY
  SELL
  @@schema("marvics")
}
enum OrderStatus {
  SUBMITTED
  FILLED
  PARTIALLY_FILLED
  FAILED
  CANCELLED
  @@schema("marvics")
}
model User {
  id               String        @id @default(uuid())
  authUserId       String        @unique
  email            String        @unique
  displayName      String?
  role             UserRole      @default(USER)
  status           AccountStatus @default(ACTIVE)
  kycStatus        KycStatus     @default(NOT_STARTED)
  twoFactorEnabled Boolean       @default(false)
  referredByCode   String?
  referralCode     String        @unique
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  ledgerEntries    LedgerEntry[]
  depositAddresses DepositAddress[]
  orders           Order[]
  conversions   Conversion[]
  transfersOut  InternalTransfer[] @relation("TransferSender")
  transfersIn   InternalTransfer[] @relation("TransferRecipient")
  @@schema("marvics")
}
model LedgerEntry {
  id            String          @id @default(uuid())
  userId        String
  user          User            @relation(fields: [userId], references: [id])
  asset         String
  amount        Decimal
  entryType     LedgerEntryType
  referenceType String
  referenceId   String
  balanceAfter  Decimal
  createdAt     DateTime        @default(now())
  createdBy     String?
  @@index([userId, asset, createdAt])
  @@schema("marvics")
}
model DepositAddress {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  chain       String
  asset       String
  address     String   @unique
  providerRef String
  createdAt   DateTime @default(now())
  depositEvents DepositEvent[]
  @@unique([userId, chain, asset])
  @@schema("marvics")
}
model DepositEvent {
  id                String         @id @default(uuid())
  depositAddressId  String
  depositAddress    DepositAddress @relation(fields: [depositAddressId], references: [id])
  txHash            String
  chain             String
  asset             String
  amount            Decimal
  confirmations     Int            @default(0)
  status            DepositStatus  @default(PENDING)
  rawWebhookPayload Json
  ledgerEntryId     String?
  createdAt         DateTime       @default(now())
  @@unique([txHash, chain])
  @@schema("marvics")
}
model Order {
  id                  String      @id @default(uuid())
  userId              String
  user                User        @relation(fields: [userId], references: [id])
  side                OrderSide
  symbol              String
  exchange            String
  exchangeOrderId     String
  requestedQty        Decimal
  filledQty           Decimal?
  filledPrice         Decimal?
  fees                Decimal?
  feeAsset            String?
  status              OrderStatus
  rawExchangeResponse Json
  ledgerEntryIds      String[]
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  @@index([userId, createdAt])
  @@schema("marvics")
}
model Conversion {
  id             String   @id @default(uuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  fromAsset      String
  toAsset        String
  fromAmount     Decimal
  toAmount       Decimal
  rateUsed       Decimal
  ledgerEntryIds String[]
  createdAt      DateTime @default(now())
  @@index([userId, createdAt])
  @@schema("marvics")
}
model InternalTransfer {
  id             String   @id @default(uuid())
  senderId       String
  sender         User     @relation("TransferSender", fields: [senderId], references: [id])
  recipientId    String
  recipient      User     @relation("TransferRecipient", fields: [recipientId], references: [id])
  asset          String
  amount         Decimal
  ledgerEntryIds String[]
  createdAt      DateTime @default(now())
  @@index([senderId, createdAt])
  @@index([recipientId, createdAt])
  @@schema("marvics")
}