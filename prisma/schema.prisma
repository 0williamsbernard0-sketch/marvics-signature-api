generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  schemas   = ["marvics"]
}

enum UserRole {
  USER
  SUPPORT
  COMPLIANCE
  SUPER_ADMIN
  @@schema("marvics")
}

enum AccountStatus {
  ACTIVE
  FROZEN
  RESTRICTED
  DELETED
  @@schema("marvics")
}

enum KycStatus {
  NOT_STARTED
  PENDING
  VERIFIED
  REJECTED
  @@schema("marvics")
}

enum LedgerEntryType {
  DEPOSIT
  WITHDRAWAL
  TRADE_BUY
  TRADE_SELL
  CONVERSION_OUT
  CONVERSION_IN
  TRANSFER_OUT
  TRANSFER_IN
  REFERRAL_REWARD
  FEE
  ADMIN_ADJUSTMENT
  @@schema("marvics")
}

enum DepositStatus {
  PENDING
  CONFIRMED
  CREDITED
  FAILED
  @@schema("marvics")
}

enum OrderSide {
  BUY
  SELL
  @@schema("marvics")
}

enum OrderStatus {
  SUBMITTED
  FILLED
  PARTIALLY_FILLED
  FAILED
  CANCELLED
  @@schema("marvics")
}

enum WithdrawalStatus {
  PENDING
  RISK_REVIEW
  APPROVED
  BROADCASTING
  COMPLETED
  REJECTED
  FAILED
  @@schema("marvics")
}

enum ModerationStatus {
  VISIBLE
  HIDDEN
  REMOVED
  @@schema("marvics")
}

enum RewardStatus {
  PENDING
  PAID
  VOIDED
  @@schema("marvics")
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
  @@schema("marvics")
}

model User {
  id               String        @id @default(uuid())
  authUserId       String        @unique
  email            String        @unique
  displayName      String?
  role             UserRole      @default(USER)
  status           AccountStatus @default(ACTIVE)
  kycStatus        KycStatus     @default(NOT_STARTED)
  twoFactorEnabled Boolean       @default(false)
  referredByCode   String?
  referralCode     String        @unique
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  ledgerEntries    LedgerEntry[]
  depositAddresses DepositAddress[]
  orders           Order[]
  conversions   Conversion[]
  transfersOut  InternalTransfer[] @relation("TransferSender")
  transfersIn   InternalTransfer[] @relation("TransferRecipient")
  auditLogs     AuditLog[]
  withdrawalRequests WithdrawalRequest[]
  communityPosts    CommunityPost[]
  communityComments CommunityComment[]
  communityLikes    CommunityLike[]
  referralRewards    ReferralReward[]
  notifications     Notification[]
  supportTickets    SupportTicket[]
  kycSubmissions     KycSubmission[]
  @@schema("marvics")
}

model LedgerEntry {
  id            String          @id @default(uuid())
  userId        String
  user          User            @relation(fields: [userId], references: [id])
  asset         String
  amount        Decimal
  entryType     LedgerEntryType
  referenceType String
  referenceId   String
  balanceAfter  Decimal
  createdAt     DateTime        @default(now())
  createdBy     String?
  @@index([userId, asset, createdAt])
  @@schema("marvics")
}

model DepositAddress {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  chain       String
  asset       String
  address     String   @unique
  providerRef String
  createdAt   DateTime @default(now())
  depositEvents DepositEvent[]
  @@unique([userId, chain, asset])
  @@schema("marvics")
}

model DepositEvent {
  id                String         @id @default(uuid())
  depositAddressId  String
  depositAddress    DepositAddress @relation(fields: [depositAddressId], references: [id])
  txHash            String
  chain             String
  asset             String
  amount            Decimal
  confirmations     Int            @default(0)
  status            DepositStatus  @default(PENDING)
  rawWebhookPayload Json
  ledgerEntryId     String?
  createdAt         DateTime       @default(now())
  @@unique([txHash, chain])
  @@schema("marvics")
}

model Order {
  id                  String      @id @default(uuid())
  userId              String
  user                User        @relation(fields: [userId], references: [id])
  side                OrderSide
  symbol              String
  exchange            String
  exchangeOrderId     String
  requestedQty        Decimal
  filledQty           Decimal?
  filledPrice         Decimal?
  fees                Decimal?
  feeAsset            String?
  status              OrderStatus
  rawExchangeResponse Json
  ledgerEntryIds      String[]
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  @@index([userId, createdAt])
  @@schema("marvics")
}

model Conversion {
  id             String   @id @default(uuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  fromAsset      String
  toAsset        String
  fromAmount     Decimal
  toAmount       Decimal
  rateUsed       Decimal
  ledgerEntryIds String[]
  createdAt      DateTime @default(now())
  @@index([userId, createdAt])
  @@schema("marvics")
}

model InternalTransfer {
  id             String   @id @default(uuid())
  senderId       String
  sender         User     @relation("TransferSender", fields: [senderId], references: [id])
  recipientId    String
  recipient      User     @relation("TransferRecipient", fields: [recipientId], references: [id])
  asset          String
  amount         Decimal
  ledgerEntryIds String[]
  createdAt      DateTime @default(now())
  @@index([senderId, createdAt])
  @@index([recipientId, createdAt])
  @@schema("marvics")
}

model AuditLog {
  id           String   @id @default(uuid())
  userId       String?
  user         User?    @relation(fields: [userId], references: [id])
  action       String   // e.g. "POST /v1/admin/freeze-account"
  method       String
  path         String
  statusCode   Int?
  requestBody  Json?
  ipAddress    String?
  createdAt    DateTime @default(now())
  @@index([userId, createdAt])
  @@schema("marvics")
}

model WithdrawalRequest {
  id                 String           @id @default(uuid())
  userId             String
  user               User             @relation(fields: [userId], references: [id])
  asset              String
  amount             Decimal
  destinationAddress String
  tier               String           // "INSTANT" | "VERIFIED"
  status             WithdrawalStatus @default(PENDING)
  requiresKyc        Boolean          @default(false)
  reviewedBy         String?
  reviewedAt         DateTime?
  rejectionReason    String?
  txHash             String?
  ledgerEntryId      String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  @@index([userId, createdAt])
  @@schema("marvics")
}

model WithdrawalSettings {
  id                String   @id @default("singleton")
  paused            Boolean  @default(false)
  pausedReason      String?
  instantTierLimit  Decimal  @default(100)
  dailyLimitInstant Decimal  @default(200)
  dailyLimitVerified Decimal @default(5000)
  updatedAt         DateTime @updatedAt
  @@schema("marvics")
}

model CommunityPost {
  id          String            @id @default(uuid())
  userId      String
  user        User              @relation(fields: [userId], references: [id])
  content     String
  imageUrls   String[]
  status      ModerationStatus  @default(VISIBLE)
  moderatedBy String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  comments    CommunityComment[]
  likes       CommunityLike[]
  @@index([status, createdAt])
  @@schema("marvics")
}

model CommunityComment {
  id        String        @id @default(uuid())
  postId    String
  post      CommunityPost @relation(fields: [postId], references: [id])
  userId    String
  user      User          @relation(fields: [userId], references: [id])
  content   String
  createdAt DateTime      @default(now())
  @@index([postId, createdAt])
  @@schema("marvics")
}

model CommunityLike {
  id        String        @id @default(uuid())
  postId    String
  post      CommunityPost @relation(fields: [postId], references: [id])
  userId    String
  user      User          @relation(fields: [userId], references: [id])
  createdAt DateTime      @default(now())
  @@unique([postId, userId])
  @@schema("marvics")
}

model ReferralReward {
  id             String       @id @default(uuid())
  referrerId     String
  referrer       User         @relation(fields: [referrerId], references: [id])
  referredUserId String
  triggerEvent   String       // "first_deposit" | "first_trade"
  asset          String
  amount         Decimal
  status         RewardStatus @default(PAID)
  ledgerEntryId  String?
  createdAt      DateTime     @default(now())
  @@unique([referredUserId, triggerEvent])
  @@index([referrerId, createdAt])
  @@schema("marvics")
}

model ReferralSettings {
  id                 String   @id @default("singleton")
  firstDepositReward Decimal  @default(5)
  firstTradeReward   Decimal  @default(2)
  rewardAsset        String   @default("USDT")
  updatedAt          DateTime @updatedAt
  @@schema("marvics")
}

model Notification {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  type      String
  title     String
  message   String
  read      Boolean   @default(false)
  readAt    DateTime?
  createdAt DateTime  @default(now())
  @@index([userId, read, createdAt])
  @@schema("marvics")
}

model SupportTicket {
  id         String           @id @default(uuid())
  userId     String
  user       User             @relation(fields: [userId], references: [id])
  subject    String
  status     TicketStatus     @default(OPEN)
  assignedTo String?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  messages   SupportMessage[]
  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@schema("marvics")
}

model SupportMessage {
  id             String        @id @default(uuid())
  ticketId       String
  ticket         SupportTicket @relation(fields: [ticketId], references: [id])
  senderId       String
  senderRole     String
  content        String
  attachmentUrls String[]      @default([])
  createdAt      DateTime      @default(now())
  @@index([ticketId, createdAt])
  @@schema("marvics")
}

model KycSubmission {
  id                 String    @id @default(uuid())
  userId             String
  user               User      @relation(fields: [userId], references: [id])
  idDocumentPath     String    // private Supabase Storage path, not a public URL
  selfiePath         String
  proofOfAddressPath String
  status             KycStatus @default(PENDING)
  reviewedBy         String?
  reviewedAt         DateTime?
  rejectionReason    String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@schema("marvics")
}